ENVIRONMENT=local
PORT=8000

# Database — points to dev Tenant DB in local postgres container (ADR-0007)
DATABASE_URL=postgres://fsi:fsi_dev@localhost:5432/tenant_dev?sslmode=disable

# NATS JetStream (ADR-0009)
NATS_URL=nats://localhost:4222

# Keycloak (ADR-0008)
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=dev-tenant

# OTel — points to local Jaeger (ADR-0012)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=ai-test-gateway-service

# Tenant — local dev fallback (ADR-0004, ADR-0011)
DEFAULT_TENANT_ID=dev-tenant
