ENVIRONMENT=local
PORT=8000

# Set to true to skip JWT validation in local dev (ADR-0011)
AUTH_DISABLED=true

# Keycloak JWKS endpoint for JWT validation (ADR-0008)
KEYCLOAK_BASE_URL=http://localhost:8080

# OTel — points to local Jaeger (ADR-0012)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=ai-test-gateway-service

# Upstream service URLs — point to locally running services (ADR-0011)
UPSTREAM_ASSETS_URL=http://localhost:8001
UPSTREAM_WORKORDERS_URL=http://localhost:8002
UPSTREAM_PM_URL=http://localhost:8003
UPSTREAM_PMSCHEDULES_URL=http://localhost:8004
UPSTREAM_FLOORPLANS_URL=http://localhost:8005
UPSTREAM_TENANTADMIN_URL=http://localhost:8006
UPSTREAM_ANALYTICS_URL=http://localhost:8007
